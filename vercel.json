{
    "redirects": [
        {
            "source": "/api/r/(.*)",
            "destination": "https://qr.lubancoffee.com/api/r/$1",
            "permanent": true
        },
        {
            "source": "/api/(.*)",
            "destination": "https://qr.lubancoffee.com/api/$1",
            "permanent": true
        },
        {
            "source": "/(.*)",
            "destination": "https://qr.lubancoffee.com/$1",
            "permanent": true
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/",
            "dest": "/public/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ]
}