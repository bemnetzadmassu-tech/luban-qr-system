{
    "version": 2,
    "functions": {
        "api/index.js": {
            "includeFiles": "public/**"
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/css/(.*)",
            "dest": "/public/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/public/js/$1"
        },
        {
            "src": "/(.*)\\.(css|js|png|jpg|jpeg|gif|svg|ico|json|woff|woff2|ttf|eot)",
            "dest": "/public/$1.$2"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)\\.(css|js)",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/css"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}