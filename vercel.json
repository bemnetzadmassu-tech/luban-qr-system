cat > vercel.json << 'EOF'
{
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/",
            "dest": "/public/test.html"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ]
}
EOF